# 개발 모드
# local 또는 development: 로컬 개발 docker php, mariadb 환경 생성으로 개발 컴퓨터에서 실행 php api 실행환경 구성
# remote: 배포 서버용 (backend/v1/api 감시 - gnuboard 경로 숨김)
DEV_MODE=local


#프론트 배포 환경
# hosting : cafe24 호스팅(php,mariadb) - adapter-stitac
# myserver : 클라우드, idc 서버(php,mariadb) - adapter-node
# cloudflare : 클라우드플레어
# versel : 버셀 
DEPLOY_FRONT=hosting

# git 저장소
GIT_REPO=



# 웹서버(nginx, apache)
WEB_SERVER=apache

# 데이터베이스 서버(mariadb, mysql)
DB_SERVER=mariadb

# php 버전
PHP_VERSION=8.4


# 앱이름
APP_NAME=
# 앱아이디 예)com.kargon.app
APP_ID=
# 앱쿠키도메인
APP_COOKIE_DOMAIN=


# ===========================================
# FTP Watch 스크립트 환경 변수 설정
# ===========================================
# scripts/ftp-watch.sh 에서 사용되는 환경 변수입니다.
# 값을 입력한 후 .env.example 을 복사하여 .env 파일을 생성하세요.

# FTP 서버 주소 (예: ftp.example.com 또는 192.168.1.100)
FTP_HOST=

# FTP 사용자명
FTP_USER=

# FTP 비밀번호
FTP_PASS=

# FTP 원격 경로 (업로드할 디렉토리 경로, 예: /public_html/api)
FTP_PATH=


