# SAPI 환경 변수 설정 파일 예제

# 애플리케이션 설정
APP_VERSION=0.0.1
APP_ENV=development
APP_DEBUG=true
APP_DOMAIN=http://localhost
APP_COOKIE_DOMAIN=
APP_HTTPS_ONLY=false
APP_COOKIE_SAMESITE=Lax 
#none : cross domain, Lax : same domain

# SQL 개발 설정(true : sqlx 실생시 마이그레이션 체크후 실행, false : 마이그레이션 실행 X)
SQL_DEV_MODE=true

# 로그 레벨 설정
# 0: 로그 생성하지 않음 (production 권장)
# 1: error만 기록
# 2: error + warning 기록
# 3: error + warning + info 기록 (development 기본값)
# 4: 모든 로그 기록 (debug 포함)
LOG_LEVEL=3

# 로그 파일 보관 기간 (일)
# 설정된 일수가 지난 로그 파일은 자동 삭제됨
# 0: 자동 삭제하지 않음
LOG_RETENTION_DAYS=30

# sqlx 디버그 설정 (쿼리 로깅)
# true: 모든 SQL 쿼리를 로그에 기록
# false: 에러만 기록 (production 권장)
SQLX_DEBUG=false

# 데이터베이스 설정 (Root .env와 동일하게 설정)
# MYSQL_HOST=mysql
# MYSQL_DATABASE=gnuboard
# MYSQL_USER=gnuboard
# MYSQL_PASSWORD=gnuboard123

# JWT 토큰 설정
JWT_ACCESS_TOKEN_KEY=your-secret-access-token-key-change-in-production
JWT_REFRESH_TOKEN_KEY=your-secret-refresh-token-key-change-in-production
JWT_CRYPT_KEY=your-secret-crypt-key-change-in-production
JWT_AUDIENCE=localhost
JWT_ACCESS_MTIME=15
JWT_REFRESH_DATE=30

# CORS 설정
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400

# Firebase 설정 Push 보내는 용도
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=123456789

# ============================================================================
# 이메일 설정 (Email Configuration)
# ============================================================================
# 이메일 제공 방식 선택
# gnuboard: 그누보드 설정 사용 (기본값)
# smtp: SMTP 직접 설정 (AWS SES, SendGrid, Gmail 등)
EMAIL_PROVIDER=gnuboard

# EMAIL_PROVIDER=smtp 사용 시 설정 (그누보드 설정 무시)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_ENCRYPTION=tls
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME="Your Service Name"

# AWS SES 사용 시 (선택)
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY_ID=your-access-key
AWS_SES_SECRET_ACCESS_KEY=your-secret-key

# ============================================================================
# SMS 설정 (SMS Configuration)
# ============================================================================
# SMS 제공 방식 선택
# gnuboard: 그누보드 설정 사용 (기본값, 그누보드 SMS 플러그인 필요)
# aligo: 알리고 서비스
# coolsms: 쿨에스엠에스 (ncloud)
# twilio: Twilio
SMS_PROVIDER=gnuboard

# SMS_PROVIDER=aligo 사용 시 설정
ALIGO_API_KEY=your-aligo-api-key
ALIGO_USER_ID=your-aligo-user-id
ALIGO_SENDER=01012345678

# SMS_PROVIDER=coolsms 사용 시 설정 (NCP)
COOLSMS_API_KEY=your-coolsms-api-key
COOLSMS_API_SECRET=your-coolsms-api-secret
COOLSMS_SENDER=01012345678

# SMS_PROVIDER=twilio 사용 시 설정
TWILIO_SID=your-twilio-sid
TWILIO_TOKEN=your-twilio-token
TWILIO_FROM_NUMBER=+1234567890

# ============================================================================
# 푸시 알림 설정 (Push Notification)
# ============================================================================
# 푸시 제공 방식 선택
# firebase: Firebase Cloud Messaging (기본값)
# none: 푸시 사용 안함
PUSH_PROVIDER=firebase

# Firebase 설정은 상단 FIREBASE_* 설정과 공유
