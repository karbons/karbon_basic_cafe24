# =============================================================================
# gnu5_api Docker Compose 환경 변수 설정
# =============================================================================
#
# 이 파일은 docker-compose.yml에서 사용되는 환경 변수의 예시 파일입니다.
# 실제 사용 시 이 파일을 .env로 복사한 후 값을 수정하세요.
#
#   cp .env.example .env
#
# =============================================================================


# =============================================================================
# 프로젝트 기본 설정
# =============================================================================

# 프로젝트 이름 (Docker 컨테이너 이름 접두사 및 네트워크/볼륨 이름에 사용)
# 예: gnu5 → gnu5_nginx, gnu5_mysql, gnu5_network 등
# 여러 프로젝트를 동시에 운영할 때 겹치지 않도록 고유한 이름을 사용하세요.
PROJECT_NAME=karbon_basic


# =============================================================================
# Nginx 웹 서버 설정
# =============================================================================

# HTTP 포트 (외부에서 접속하는 포트 → 컨테이너 80포트로 매핑)
# 기본값: 80
# 다른 웹 서버가 80포트를 사용 중이면 8000, 8888 등으로 변경하세요.
HTTP_PORT=80

# HTTPS 포트 (SSL 인증서 설정 시 사용)
# 기본값: 443
HTTPS_PORT=443


# =============================================================================
# PHP 설정
# =============================================================================

# PHP 버전 (Dockerfile.php 빌드 시 사용)
# 지원 버전: 7.4, 8.0, 8.1, 8.2, 8.3
# 그누보드5는 PHP 7.4 이상 권장, SAPI는 PHP 8.1 이상 권장
PHP_VERSION=8.1

# PHP 메모리 제한
# 기본값: 256M
# 대용량 파일 처리나 복잡한 쿼리 시 512M 이상 권장
PHP_MEMORY_LIMIT=256M

# PHP 최대 실행 시간 (초)
# 기본값: 300 (5분)
# API 타임아웃에 영향을 줍니다. 대용량 작업이 있으면 늘리세요.
PHP_MAX_EXECUTION_TIME=300

# 파일 업로드 최대 크기
# 기본값: 100M
# 이미지/동영상 업로드가 필요하면 적절히 조절하세요.
# 주의: PHP_POST_MAX_SIZE보다 작거나 같아야 합니다.
PHP_UPLOAD_MAX_FILESIZE=100M

# POST 요청 최대 크기
# 기본값: 100M
# PHP_UPLOAD_MAX_FILESIZE보다 크거나 같아야 합니다.
PHP_POST_MAX_SIZE=100M


# =============================================================================
# MySQL 데이터베이스 설정
# =============================================================================

# MySQL root 비밀번호
# ⚠️ 운영 환경에서는 반드시 강력한 비밀번호로 변경하세요!
MYSQL_ROOT_PASSWORD=rootpassword

# 그누보드용 데이터베이스 이름
# 기본값: gnuboard
# Docker 최초 실행 시 이 이름으로 데이터베이스가 자동 생성됩니다.
MYSQL_DATABASE=gnuboard

# 그누보드용 데이터베이스 사용자 이름
# 기본값: gnuboard
# Docker 최초 실행 시 이 사용자가 MYSQL_DATABASE에 대한 권한과 함께 자동 생성됩니다.
MYSQL_USER=gnuboard

# 그누보드용 데이터베이스 사용자 비밀번호
# ⚠️ 운영 환경에서는 반드시 강력한 비밀번호로 변경하세요!
# 이 값은 phpMyAdmin, SAPI API(.env)에서도 동일하게 사용됩니다.
MYSQL_PASSWORD=gnuboard123

# MySQL 외부 접속 포트
# 기본값: 3306
# 호스트 PC에서 MySQL Workbench, DBeaver 등으로 접속할 때 이 포트를 사용합니다.
# 다른 MySQL이 이미 3306을 사용 중이면 33060 등으로 변경하세요.
MYSQL_PORT=3306


# =============================================================================
# Redis 설정
# =============================================================================

# Redis 외부 접속 포트
# 기본값: 6379
# 세션 저장, 캐싱 등에 사용됩니다.
# 다른 Redis가 이미 6379를 사용 중이면 63790 등으로 변경하세요.
REDIS_PORT=6379


# =============================================================================
# phpMyAdmin 설정
# =============================================================================

# phpMyAdmin 웹 접속 포트
# 기본값: 8080
# 브라우저에서 http://localhost:8080 으로 접속하여 DB를 관리할 수 있습니다.
# MYSQL_USER, MYSQL_PASSWORD 값으로 자동 로그인됩니다.
PMA_PORT=8080
